{
    "version": 2,
    "framework": null,
    "buildCommand": "mkdir -p dist && cp -r public/* dist/",
    "outputDirectory": "dist",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|favicon)/(.*)",
            "dest": "/$1/$2"
        },
        {
            "src": "/(.*)\\.(ico|png|jpg|jpeg|gif|svg|txt|css|js|webmanifest)$",
            "dest": "/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:3uJb7aY77gO8yNqE0v9jZ5fC9bQxT2pY1u7oN9aE3c8=",
        "LOG_CHANNEL": "stderr",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "database/database.sqlite"
    }
}
